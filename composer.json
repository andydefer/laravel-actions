{
    "name": "andydefer/laravel-actions",
    "description": "Action-oriented architecture for Laravel applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Defer",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "inertiajs/inertia-laravel": "^2.0|^3.0",
        "ramsey/uuid": "^4.7",
        "andydefer/domain-structures": "^1.21.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\Actions\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\Actions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\Actions\\ActionServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
